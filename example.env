# ---------------------------------------------------------------------------
# Talk Budget environment configuration
# Copy this file to `.env` and fill in the real secrets:
#     cp example.env .env
# ---------------------------------------------------------------------------

# --- App ---
PROJECT_NAME=Talk Budget
ENVIRONMENT=development

# --- PostgreSQL ---
POSTGRES_USER=talkbudget
POSTGRES_PASSWORD=talkbudget
POSTGRES_DB=talkbudget
POSTGRES_HOST=postgres-db
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis-cache
REDIS_PORT=6379

# --- Security / JWT ---
# Generate a strong value, e.g. `openssl rand -hex 32`
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Default admin seed (created on backend startup if missing) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@talkbudget.com

# --- AI Agent Gateway (OpenCode API, OpenAI-compatible) ---
OPENCODE_API_KEY=your-opencode-api-key-here
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1
AI_MODEL=deepseek-v4-flash
